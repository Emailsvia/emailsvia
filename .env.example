# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; this file is NOT — never paste real secrets here.

# ---- Supabase (Settings → API) ----
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ---- Gmail SMTP fallback ----
# Only used if a campaign doesn't specify a sender. Generate an app password
# at https://myaccount.google.com/apppasswords (needs 2FA enabled).
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
GMAIL_FROM_NAME=Your Name

# ---- Auth ----
# Sign-in is now Supabase Auth (email+password and Google OAuth). Supabase
# manages the session cookie itself, so there's no APP_PASSWORD or session
# secret here. To enable Google sign-in, configure Google as an auth provider
# in your Supabase project (Auth → Providers → Google) and set the redirect
# URL to {APP_URL}/auth/callback.

# ---- Encryption secret (32+ chars) ----
# Used to encrypt sender Gmail credentials at rest (AES-GCM) and to sign
# tracking-pixel + unsubscribe tokens (HMAC). Rotate carefully — encrypted
# columns become unreadable if you change it without re-encrypting.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET=change-me-to-a-random-32-plus-char-string

# ---- Sender Gmail OAuth (Phase 1.3) ----
# Used to let users connect their Gmail via OAuth instead of an app password.
# Create credentials at https://console.cloud.google.com/apis/credentials.
# Type: "Web application". Authorized redirect URI:
#   {APP_URL}/api/auth/google/callback
# Scopes used at runtime: gmail.send, gmail.readonly, userinfo.email.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---- Postmark transactional (Phase 4) ----
# Used for system-side mail: "your sender disconnected", dunning notices,
# password resets-from-us. Kept off the user's Gmail so a bad sending day
# from EmailsVia doesn't tank a user's deliverability. Without these set,
# notifications are swallowed (logged, never sent).
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=hello@emailsvia.com
POSTMARK_FROM_NAME=EmailsVia
# Postmark message stream id (transactional/broadcast); default is
# "outbound" — change only if you've created a custom stream in the Postmark UI.
POSTMARK_MESSAGE_STREAM=outbound

# ---- Anthropic (Phase 3.3) ----
# Used by check-replies for AI reply triage on Growth/Scale plans.
# Calls claude-haiku-4-5 (~$0.0001/reply at break-even cache).
# Without this set, replies still arrive — they just don't get an `intent`
# label and the filter chips on /app/replies stay empty.
ANTHROPIC_API_KEY=

# ---- Sentry (Phase 1.6) ----
# Public DSN is exposed to the browser bundle so client errors flow too.
# Without these set, all Sentry init becomes a no-op (safe default for dev).
NEXT_PUBLIC_SENTRY_DSN=
# Optional: source-map upload during build. Without an auth token the
# build still succeeds — you just lose symbolicated client stack traces.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ---- Admin dashboard (Phase 1.6) ----
# Comma-separated list of Supabase auth.users ids allowed to load /app/admin
# and /api/admin. Match the uuid you see in Supabase Auth > Users for your
# own account.
ADMIN_USER_IDS=

# ---- Stripe billing (Phase 1.4) ----
# Get keys at https://dashboard.stripe.com/apikeys. Use test keys (sk_test_,
# pk_test_) until launch. Stripe Tax is on day-one — enable it in dashboard
# under Settings -> Tax.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret from Dashboard -> Developers -> Webhooks. Subscribe the
# endpoint to: customer.subscription.created/updated/deleted, invoice.payment_failed.
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Price IDs for each paid tier (create monthly recurring prices in
# Dashboard, copy the price_... id). Free tier doesn't need a price id.
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_SCALE=price_...

# ---- Cron authentication ----
# Generate the same way. Used by the Supabase pg_cron → /api/tick caller.
CRON_SECRET=change-me-to-another-random-string

# ---- Public URL (production) ----
# Used for tracking pixels, click-tracked links, and unsubscribe URLs.
# Set to your deployed URL (https://yourapp.vercel.app) in production.
APP_URL=http://localhost:3000
