{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "crons": [
    {
      "path": "/api/tick",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/check-replies",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/refresh-tokens",
      "schedule": "7 * * * *"
    }
  ],

  "functions": {
    "src/app/api/tick/route.ts": { "maxDuration": 60 },
    "src/app/api/check-replies/route.ts": { "maxDuration": 60 },
    "src/app/api/cron/refresh-tokens/route.ts": { "maxDuration": 60 },
    "src/app/api/v1/campaigns/from-sheet/route.ts": { "maxDuration": 60 },
    "src/app/api/test-send/route.ts": { "maxDuration": 30 },
    "src/app/api/campaigns/[id]/validate/route.ts": { "maxDuration": 60 },
    "src/app/api/campaigns/[id]/recipients/route.ts": { "maxDuration": 60 },
    "src/app/api/campaigns/[id]/recipients/sheets/route.ts": { "maxDuration": 60 }
  }
}
